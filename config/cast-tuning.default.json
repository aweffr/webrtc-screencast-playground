{
  "schema_version": 3,
  "profile": "DETAIL_ACTIVE",
  "sender": {
    "max_width": 1920,
    "max_height": 1080,
    "max_fps": 15,
    "content_mode": "TEXT",
    "min_bitrate_bps": 400000,
    "start_bitrate_bps": 3000000,
    "max_bitrate_bps": 5000000,
    "degradation_preference": "MAINTAIN_RESOLUTION",
    "network_priority": "HIGH"
  },
  "transport": {
    "disable_tcp_candidates": true,
    "screencast_min_bitrate_bps": 400000
  },
  "pacing": {
    "screenshare_alr_probing": true,
    "factor": 1.1,
    "max_queue_ms": 100
  },
  "encoder": {
    "hardware_policy": "PREFER_HARDWARE",
    "realtime": true,
    "allow_frame_reordering": false,
    "max_frame_delay_count": 1,
    "max_qp": 32,
    "video_toolbox_low_latency_rate_control": false,
    "video_toolbox_spatial_adaptive_qp": "DEFAULT"
  },
  "receiver": {
    "jitter_minimum_ms": 0,
    "prerender_smoothing": false,
    "render_lead_ms": 10,
    "android_decoder_low_latency": true,
    "stale_decoded_frame_ms": 150
  },
  "recovery": {
    "nack_enabled": true,
    "nack_history_ms": 1000,
    "rtx_enabled": true,
    "fec_mode": "DISABLED",
    "pli_min_interval_ms": 300,
    "no_decoded_frame_timeout_ms": 150,
    "decoder_recreate_after_failed_pli": 2,
    "sender_reset_after_failed_pli": 3
  },
  "telemetry": {
    "sample_interval_ms": 1000
  }
}
