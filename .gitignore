# Downloaded release assets and generated experiment evidence remain local.
# SHA256SUMS is the only versioned contract in the artifacts workspace.
/artifacts/*
!/artifacts/SHA256SUMS

# Runtime credentials and machine-local configuration must never be committed.
secrets/
Config/Local.xcconfig

# Xcode local state and build output.
.DS_Store
DerivedData/
build/
*.xcuserstate
xcuserdata/

# Generated dependencies and language build state.
Vendor/
.swiftpm/
.build/
apps/android-tv/.gradle/
apps/android-tv/local.properties
apps/android-tv/**/build/
__pycache__/
server/signaling-server

# Local runtime configuration and collected diagnostics.
runtime.json
diagnostics/
apps/android-tv/app/src/debug/res/values/reference_runtime.local.xml
